  <head>
    <meta content='l_costal_cartilage.x3d' name='title'/>
    <meta content='costal cartilage, also known as rib cartilage, are bars of hyaline cartilage that serve to prolong the ribs forward and contribute to elasticity of walls of thorax' name='description'/>
