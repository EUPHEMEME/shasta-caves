  <head>
    <meta content='r_clavicle.x3d' name='title'/>
    <meta content='clavicle, collarbone, or keybone is a slender, S-shaped long bone that serves as a strut between shoulder blade and sternum (breastbone)' name='description'/>
    <meta content='Don Brutzman, Joe Williams, John Carlson, Damon Hernandez' name='creator'/>
