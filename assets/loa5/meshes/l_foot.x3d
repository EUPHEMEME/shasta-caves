    <meta content='l_foot.x3d' name='title'/>
    <meta content='The foot is terminal limb of the leg, containing many bones. This model composes l_calcaneus, l_cuboid, l_cuneiform_1, l_cuneiform_2, l_cuneiform_3, l_metatarsal_1, l_metatarsal_2, l_metatarsal_3, l_metatarsal_4, l_metatarsal_5, l_navicular, l_talus, l_tarsal_distal_phalanx_1, l_tarsal_distal_phalanx_2, l_tarsal_distal_phalanx_3, l_tarsal_distal_phalanx_4, l_tarsal_distal_phalanx_5, l_tarsal_middle_phalanx_2, l_tarsal_middle_phalanx_3, l_tarsal_middle_phalanx_4, l_tarsal_middle_phalanx_5, l_tarsal_proximal_phalanx_1, l_tarsal_proximal_phalanx_2, l_tarsal_proximal_phalanx_3, l_tarsal_proximal_phalanx_4, l_tarsal_proximal_phalanx_5' name='description'/>
