  <Scene>
    <WorldInfo title='skull.x3d'/>
    <Background skyColor='0.858824 1 0.94902'/>
    <Transform DEF='SkullLocalOffset' translation='0 1.68 0'>
      <ViewpointGroup DEF='ViewpointGroup_skull' description='skull model' retainUserOffsets='true'>
        <Viewpoint DEF='ViewFromFront' description='skull LOA-1 face from front' nearDistance='0.001' position='0 0 0.5' retainUserOffsets='true'/>
        <Viewpoint DEF='ViewFromBehind' description='skull LOA-1 from left side' nearDistance='0.001' orientation='0 1 0 1.5708' position='0.5 0 0' retainUserOffsets='true'/>
        <Viewpoint DEF='ViewFromLeft' description='skull LOA-1 from behind' nearDistance='0.001' orientation='0 1 0 3.1416' position='0 0 -0.5' retainUserOffsets='true'/>
        <Viewpoint DEF='ViewFromRight' description='skull LOA-1 from right side' nearDistance='0.001' orientation='0 1 0 -1.5708' position='-0.5 0 0' retainUserOffsets='true'/>
        <Viewpoint DEF='ViewFromAbove' description='skull LOA-1 from above' nearDistance='0.001' orientation='1 0 0 -1.5708' position='0 0.5 0' retainUserOffsets='true'/>
        <Viewpoint DEF='ViewFromBelow' description='skull LOA-1 from below' nearDistance='0.001' orientation='1 0 0 1.5708' position='0 -0.5 0' retainUserOffsets='true'/>
      </ViewpointGroup>
    </Transform>
