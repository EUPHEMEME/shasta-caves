  <head>
    <meta content='sacrum_bone.x3d' name='title'/>
    <meta content='triangular bone at base of spine that forms by fusing of sacral vertebrae (s1-s5) between ages 18 and 30, situated at upper, back part of pelvic cavity, between two wings of pelvis' name='description'/>
