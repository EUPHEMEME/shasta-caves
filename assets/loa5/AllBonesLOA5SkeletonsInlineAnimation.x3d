    <Transform DEF='SkeletonLeft'>
      <HAnimHumanoid DEF='hanim_AllBonesSkeleton' loa='5' name='AllBonesSkeleton' version='2.0'>
        <MetadataSet containerField='metadata' name='HAnimHumanoid.info' reference='https://www.web3d.org/documents/specifications/19774/V2.0/Architecture/ObjectInterfaces.html#Humanoid'>
          <!-- TODO add HAnim metadata -->
        </MetadataSet>
        <!-- TODO where is humanoid_root center? seat of pants? relationship to sacroiliac and vl5? -->
        <HAnimJoint DEF='hanim_humanoid_root' containerField='skeleton' center='0 0.826 -0.016' name='humanoid_root'>
          <HAnimSegment DEF='hanim_sacrum' name='sacrum'>
            <!-- virtual segment suitable for visualization -->
            <!-- Mantis 1536: segment "sacrum" is name associated with humanoid_root joint, but anatomically sacrum_bone is considered part of pelvis -->
          </HAnimSegment>
          <HAnimJoint DEF='hanim_sacroiliac' center='0.0005 1.015 -0.0369' name='sacroiliac'>
            <HAnimSegment DEF='hanim_pelvis' name='pelvis'>
              <!-- pelvis includes sacrum_bone, l_hip_bone, r_hip_bone, pubic_symphysis, coccyx -->
              <!-- pelvis/sacrum_bone offset to match joint socket: -->
              <!-- pelvis/sacrum_bone.x3d + translation +0.0005 +0.9750 -0.0769 -->
              <!-- pelvis/sacrum_bone.x3d adjusted axes +0.0000 +0.0400 +0.0400 -->
              <!-- pelvis/sacrum_bone.x3d =joint center +0.0005 +1.0150 -0.0369 -->
              <Transform DEF='YellowBoxAtJointCenter_pelvis' translation='0.0005 1.015 -0.0369'>
                <Shape DEF='BoxShape'>
                  <Appearance>
                    <Material diffuseColor='0.9 0.9 0.4'/>
                  </Appearance>
                  <Box size='0.03 0.03 0.03'/>
                </Shape>
              </Transform>
              <!-- Duplicative geometry: <Inline DEF='pelvis_Inline' url='"pelvis.x3d"'/> -->
              <Inline DEF='sacrum_bone_Inline' url='"sacrum_bone.x3d"'/>
            </HAnimSegment>
            <HAnimSegment DEF='hanim_l_hip_bone' name='l_hip_bone'>
              <Inline DEF='l_hip_bone_Inline' url='"l_hip_bone.x3d"'/>
            </HAnimSegment>
            <HAnimSegment DEF='hanim_r_hip_bone' name='r_hip_bone'>
              <Inline DEF='r_hip_bone_Inline' url='"r_hip_bone.x3d"'/>
            </HAnimSegment>
            <HAnimSegment DEF='hanim_pubic_symphysis' name='pubic_symphysis'>
              <Inline DEF='pubic_symphysis_Inline' url='"pubic_symphysis.x3d"'/>
            </HAnimSegment>
            <HAnimSegment DEF='hanim_coccyx' name='coccyx'>
              <Inline DEF='coccyx' url='"coccyx.x3d"'/>
            </HAnimSegment>
            <HAnimJoint DEF='hanim_l_hip' center='0.0695 0.9238 -0.0254' name='l_hip'>
              <HAnimSegment DEF='hanim_l_thigh' name='l_thigh'>
                <!-- l_thigh includes l_femur -->
                <!-- Duplicative geometry: <Inline DEF='l_thigh_Inline' url='"l_thigh.x3d"'/> -->
                <Transform DEF='YellowBoxAtJointCenter_l_thigh' translation='0.0695 0.9238 -0.0254'>
                  <Shape USE='BoxShape'/>
                </Transform>
              </HAnimSegment>
              <HAnimSegment DEF='hanim_l_femur' name='l_femur'>
                <!-- l_femur offset to match joint socket: -->
                <!-- computations follow from ComputeBoneOffsetsForJointCenters for parent joint center of rotation -->
                <!-- bone l_femur.x3d + translation +0.0955 +0.6988 -0.0384 -->
                <!-- bone l_femur.x3d adjusted axes -0.0260 +0.2250 +0.0130 -->
                <!-- bone l_femur.x3d =joint center +0.0695 +0.9238 -0.0254 -->
                <Inline DEF='l_femur' url='"l_femur.x3d"'/>
              </HAnimSegment>
              <HAnimJoint DEF='hanim_l_knee' center='0.0858 0.4633 -0.0342' name='l_knee'>
                <HAnimSegment DEF='hanim_l_calf' name='l_calf'>
                  <!-- calf includes patella, tibia and fibula in loa5 -->
                  <!-- Duplicative geometry: <Inline DEF='l_calf_Inline' url='"l_calf.x3d"'/> -->
                  <Transform DEF='YellowBoxAtJointCenter_l_knee' translation='0.0858 0.4633 -0.0342'>
                    <Shape USE='BoxShape'/>
                  </Transform>
                </HAnimSegment>
                <HAnimSegment DEF='hanim_l_patella' name='l_patella'>
                  <Inline DEF='l_patella' url='"l_patella.x3d"'/>
                </HAnimSegment>
                <HAnimSegment DEF='hanim_l_tibia' name='l_tibia'>
                  <!-- l_tibia.x3d is knee bone used to adjust and match joint socket: -->
                  <!-- computations follow from ComputeBoneOffsetsForJointCenters for parent joint center of rotation -->
                  <!-- bone l_tibia.x3d + translation +0.0858 +0.2663 -0.0542 -->
                  <!-- bone l_tibia.x3d adjusted axes +0.0000 +0.1970 +0.0200 -->
                  <!-- bone l_tibia.x3d =joint center +0.0858 +0.4633 -0.0342 -->
                  <Inline DEF='l_tibia' url='"l_tibia.x3d"'/>
                </HAnimSegment>
                <HAnimSegment DEF='hanim_l_fibula' name='l_fibula'>
                  <Inline DEF='l_fibula' url='"l_fibula.x3d"'/>
                </HAnimSegment>
                <HAnimJoint DEF='hanim_l_talocrural' center='0.0741 0.0829 -0.0641' name='l_talocrural'>
                  <!-- Duplicative geometry: <Inline DEF='l_foot_Inline' url='"l_foot.x3d"'/> -->
                  <HAnimSegment DEF='hanim_l_talus' name='l_talus'>
                    <!-- ankle -->
                    <!-- computations follow from ComputeBoneOffsetsForJointCenters for parent joint center of rotation -->
                    <!-- bone l_talus.x3d + translation +0.0741 +0.0629 -0.0641 -->
                    <!-- bone l_talus.x3d adjusted axes +0.0000 +0.0200 +0.0000 -->
                    <!-- bone l_talus.x3d =joint center +0.0741 +0.0829 -0.0641 -->
                    <Inline DEF='l_talus' url='"l_talus.x3d"'/>
                    <Transform DEF='YellowBoxAtJointCenter_l_talocrural' scale='0.8 0.8 0.8' translation='0.0741 0.0829 -0.0641'>
                      <Shape USE='BoxShape'/>
                    </Transform>
                  </HAnimSegment>
                  <HAnimJoint DEF='hanim_l_talocalcaneonavicular' center='0.0606 0.0515 -0.0348' name='l_talocalcaneonavicular'>
                    <HAnimSegment DEF='hanim_l_navicular' name='l_navicular'>
                      <Inline DEF='l_navicular' url='"l_navicular.x3d"'/>
                    </HAnimSegment>
                    <HAnimJoint DEF='hanim_l_cuneonavicular_1' center='0.0673 0.0499 -0.0161' name='l_cuneonavicular_1'>
                      <HAnimSegment DEF='hanim_l_cuneiform_1' name='l_cuneiform_1'>
                        <Inline DEF='l_cuneiform_1' url='"l_cuneiform_1.x3d"'/>
                      </HAnimSegment>
                      <HAnimJoint DEF='hanim_l_tarsometatarsal_1' center='0.0622 0.0268 0.0273' name='l_tarsometatarsal_1'>
                        <HAnimSegment DEF='hanim_l_metatarsal_1' name='l_metatarsal_1'>
                          <Inline DEF='l_metatarsal_1' url='"l_metatarsal_1.x3d"'/>
                        </HAnimSegment>
                        <HAnimJoint DEF='hanim_l_metatarsophalangeal_1' center='0.0662 0.0109 0.0729' name='l_metatarsophalangeal_1'>
                          <HAnimSegment DEF='hanim_l_tarsal_proximal_phalanx_1' name='l_tarsal_proximal_phalanx_1'>
                            <Inline DEF='l_tarsal_proximal_phalanx_1' url='"l_tarsal_proximal_phalanx_1.x3d"'/>
                          </HAnimSegment>
                          <HAnimJoint DEF='hanim_l_tarsal_interphalangeal_1' center='0.0683 0.0052 0.0961' name='l_tarsal_interphalangeal_1'>
                            <HAnimSegment DEF='hanim_l_tarsal_distal_phalanx_1' name='l_tarsal_distal_phalanx_1'>
                              <Inline DEF='l_tarsal_distal_phalanx_1' url='"l_tarsal_distal_phalanx_1.x3d"'/>
                            </HAnimSegment>
                          </HAnimJoint>
                        </HAnimJoint>
                      </HAnimJoint>
                    </HAnimJoint>
                    <HAnimJoint DEF='hanim_l_cuneonavicular_2' center='0.0837 0.0478 -0.0212' name='l_cuneonavicular_2'>
                      <HAnimSegment DEF='hanim_l_cuneiform_2' name='l_cuneiform_2'>
                        <Inline DEF='l_cuneiform_2' url='"l_cuneiform_2.x3d"'/>
                      </HAnimSegment>
                      <HAnimJoint DEF='hanim_l_tarsometatarsal_2' center='0.0775 0.0345 0.0239' name='l_tarsometatarsal_2'>
                        <HAnimSegment DEF='hanim_l_metatarsal_2' name='l_metatarsal_2'>
                          <Inline DEF='l_metatarsal_2' url='"l_metatarsal_2.x3d"'/>
                        </HAnimSegment>
                        <HAnimJoint DEF='hanim_l_metatarsophalangeal_2' center='0.089 0.0164 0.0573' name='l_metatarsophalangeal_2'>
                          <HAnimSegment DEF='hanim_l_tarsal_proximal_phalanx_2' name='l_tarsal_proximal_phalanx_2'>
                            <!-- computations follow from ComputeBoneOffsetsForJointCenters for parent joint center of rotation -->
                            <!-- bone l_tarsal_proximal_phalanx_2.x3d + translation +0.0890 +0.0114 +0.0703 -->
                            <!-- bone l_tarsal_proximal_phalanx_2.x3d adjusted axes +0.0000 +0.0050 -0.0130 -->
                            <!-- bone l_tarsal_proximal_phalanx_2.x3d =joint center +0.0890 +0.0164 +0.0573 -->
                            <Inline DEF='l_tarsal_proximal_phalanx_2' url='"l_tarsal_proximal_phalanx_2.x3d"'/>
                          </HAnimSegment>
                          <HAnimJoint DEF='hanim_l_tarsal_proximal_interphalangeal_2' center='0.0945 0.0056 0.0925' name='l_tarsal_proximal_interphalangeal_2'>
                            <HAnimSegment DEF='hanim_l_tarsal_middle_phalanx_2' name='l_tarsal_middle_phalanx_2'>
                              <Inline DEF='l_tarsal_middle_phalanx_2' url='"l_tarsal_middle_phalanx_2.x3d"'/>
                            </HAnimSegment>
                            <HAnimJoint DEF='hanim_l_tarsal_distal_interphalangeal_2' center='0.0969 0.0037 0.1046' name='l_tarsal_distal_interphalangeal_2'>
                              <HAnimSegment DEF='hanim_l_tarsal_distal_phalanx_2' name='l_tarsal_distal_phalanx_2'>
                                <Inline DEF='l_tarsal_distal_phalanx_2' url='"l_tarsal_distal_phalanx_2.x3d"'/>
                              </HAnimSegment>
                            </HAnimJoint>
                          </HAnimJoint>
                        </HAnimJoint>
                      </HAnimJoint>
                    </HAnimJoint>
                    <HAnimJoint DEF='hanim_l_cuneonavicular_3' center='0.0558 0.0427 -0.0109' name='l_cuneonavicular_3'>
