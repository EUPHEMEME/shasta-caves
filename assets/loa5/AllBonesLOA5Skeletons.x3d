            <HAnimJoint DEF='hanim_r_hip' center='-0.0695 +0.9238 -0.0254' name='r_hip'>
              <HAnimSegment DEF='hanim_r_thigh' name='r_thigh'>
                <!-- thigh bone is femur -->
                <!-- Duplicative geometry: <Inline DEF='r_thigh_Inline' url='"r_thigh.x3d"'/> -->
                <!-- r_thigh includes r_femur -->
                <!-- r_femur offset to match joint socket: -->
                <!-- r_femur.x3d + translation -0.0955 +0.6988 -0.0384 -->
                <!-- r_femur.x3d adjusted axes +0.0260 +0.2250 +0.0130 -->
                <!-- r_femur.x3d =joint center -0.0695 +0.9238 -0.0254 -->
                <Transform DEF='YellowBoxAtJointCenter_r_thigh' translation='-0.0695 +0.9238 -0.0254'>
                  <Shape USE='BoxShape'/>
                </Transform>
              </HAnimSegment>
              <HAnimSegment DEF='hanim_r_femur' name='r_femur'>
                <Inline DEF='r_femur' url='"r_femur.x3d"'/>
              </HAnimSegment>
              <HAnimJoint DEF='hanim_r_knee' center='-0.0858 +0.4633 -0.0342' name='r_knee'>
                <!-- r_tibia.x3d is knee bone used for offset to match joint socket: -->
                <!-- r_tibia.x3d + translation -0.0858 +0.2663 -0.0542 -->
