    <WorldInfo title='AllBonesLOA5Skeletons.x3d'/>
    <Background skyColor='0.858824 1 0.94902'/>
    <Viewpoint centerOfRotation='0 1 0' description='AllBonesLOA5Skeletons models' position='0 1 3'/>
    <Viewpoint centerOfRotation='0.5 1 0' description='Right Humanoid, InlineGeometry meshes' position='0.5 1 3'/>
    <Viewpoint centerOfRotation='-0.5 1 0' description='Left Humanoid, Inline bone models' position='-0.5 1 3'/>
    <Group DEF='JinLOA4' visible='false'>
      <!-- Note that Jin is shorter than the Bones skeletons, but everybody has their feet on the floor at local y=0 -->
      <Inline DEF='JinLOA4Model' url='"../Characters/JinLOA4.x3d" "https://www.web3d.org/x3d/content/examples/HumanoidAnimation/Bones/../Characters/JinLOA4.x3d" "../Characters/JinLOA4.wrl" "https://www.web3d.org/x3d/content/examples/HumanoidAnimation/Bones/../Characters/JinLOA4.wrl"'/>
      <!-- Grid overlay authoring hint: first adjust grid scale to convenient large size, then adjust overall scale for your scene model. Default block size 1m by 1m. -->
      <Transform DEF='GridXY_20x20Fixed_AdjustScale' scale='1 1 1'>
        <Inline DEF='GridXY_20x20Fixed' url='"../../Savage/Tools/Authoring/GridXY_20x20Fixed.x3d" "https://www.web3d.org/x3d/content/examples/Savage/Tools/Authoring/GridXY_20x20Fixed.x3d" "../../Savage/Tools/Authoring/GridXY_20x20Fixed.wrl" "https://www.web3d.org/x3d/content/examples/Savage/Tools/Authoring/GridXY_20x20Fixed.wrl"'/>
        <Shape>
          <Appearance DEF='HighlightAppearance'>
            <Material DEF='HighlightMaterial' diffuseColor='0.9 0.9 0.3'/>
          </Appearance>
        </Shape>
      </Transform>
    </Group>
    <Transform DEF='SkeletonLeft' translation='-0.5 0 0'>
      <Transform DEF='TextLeftTranslation' translation='-0.8 1.1 0'>
        <Shape DEF='TextShapeInline'>
          <Text solid='false' string='"Inline" "bone models for" "HAnimHumanoid" "" "" "Absolute locations" "for bone models" "in each HAnimJoint" "and HAnimSegment"'>
            <FontStyle DEF='TextFontStyleDefault' family='"SANS"' justify='"MIDDLE" "MIDDLE"' size='0.1' style='BOLD'/>
          </Text>
          <Appearance DEF='TextAppearanceDefault'>
            <Material diffuseColor='0.6 0.6 0.6'/>
          </Appearance>
        </Shape>
      </Transform>
      <HAnimHumanoid DEF='hanim_AllBonesSkeleton' loa='5' name='AllBonesSkeleton' version='2.0'>
        <MetadataSet containerField='metadata' name='HAnimHumanoid.info' reference='https://www.web3d.org/documents/specifications/19774/V2.0/Architecture/ObjectInterfaces.html#Humanoid'>
          <!-- TODO add HAnim metadata -->
        </MetadataSet>
        <!-- TODO where is humanoid_root center? seat of pants? relationship to sacroiliac and vl5? -->
        <HAnimJoint DEF='hanim_humanoid_root' center='0 0.826 -0.016' containerField='skeleton' name='humanoid_root'>
          <HAnimSegment DEF='hanim_sacrum' name='sacrum'>
            <!-- virtual segment suitable for visualization -->
            <!-- Mantis 1536: segment "sacrum" is name associated with humanoid_root joint, but anatomically sacrum_bone is considered part of pelvis -->
          </HAnimSegment>
          <HAnimJoint DEF='hanim_sacroiliac' center='+0.0005 +1.0150 -0.0369' name='sacroiliac'>
            <HAnimSegment DEF='hanim_pelvis' name='pelvis'>
              <!-- pelvis includes sacrum_bone, l_hip_bone, r_hip_bone, pubic_symphysis, coccyx -->
              <!-- pelvis/sacrum_bone offset to match joint socket: -->
              <!-- pelvis/sacrum_bone.x3d + translation +0.0005 +0.9750 -0.0769 -->
              <!-- pelvis/sacrum_bone.x3d adjusted axes +0.0000 +0.0400 +0.0400 -->
              <!-- pelvis/sacrum_bone.x3d =joint center +0.0005 +1.0150 -0.0369 -->
              <Transform DEF='YellowBoxAtJointCenter_pelvis' translation='+0.0005 +1.0150 -0.0369'>
                <Shape DEF='BoxShape'>
                  <Box size='.03 .03 .03'/>
                  <Appearance>
                    <Material diffuseColor='0.9 0.9 0.4'/>
                  </Appearance>
                </Shape>
              </Transform>
              <!-- Duplicative geometry: <Inline DEF='pelvis_Inline' url='"pelvis.x3d"'/> -->
              <Inline DEF='sacrum_bone_Inline' url='"sacrum_bone.x3d"'/>
            </HAnimSegment>
            <HAnimSegment DEF='hanim_l_hip_bone' name='l_hip_bone'>
              <Inline DEF='l_hip_bone_Inline' url='"l_hip_bone.x3d"'/>
            </HAnimSegment>
            <HAnimSegment DEF='hanim_r_hip_bone' name='r_hip_bone'>
              <Inline DEF='r_hip_bone_Inline' url='"r_hip_bone.x3d"'/>
            </HAnimSegment>
            <HAnimSegment DEF='hanim_pubic_symphysis' name='pubic_symphysis'>
              <Inline DEF='pubic_symphysis_Inline' url='"pubic_symphysis.x3d"'/>
            </HAnimSegment>
            <HAnimSegment DEF='hanim_coccyx' name='coccyx'>
              <Inline DEF='coccyx' url='"coccyx.x3d"'/>
            </HAnimSegment>
            <HAnimJoint DEF='hanim_l_hip' center='+0.0695 +0.9238 -0.0254' name='l_hip'>
              <HAnimSegment DEF='hanim_l_thigh' name='l_thigh'>
                <!-- thigh bone is femur -->
