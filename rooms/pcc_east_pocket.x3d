<X3D profile="Immersive" version="4.0">
<head>
  <meta name="title" content="East-Wall Pocket (tunnel opposite the Altar) (Potter Creek)"/>
  <meta name="description" content="Existence, position in the east wall opposite the Altar, the irregular entrance ~12 ft above the floor, the ~15 ft downward run and the calcareous bone-bearing fill."/>
  <meta name="rights" content="Interpretive: Bore width/height (described only as small / irregular; ~4 x 4 ft in the model). LAYOUT: global_position/level_order/stream_bbox are interpretive staging for the unified walkable level, not survey geo"/>
</head>
