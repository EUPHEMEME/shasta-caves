<X3D profile="Immersive" version="4.0">
<head>
  <meta name="title" content="Narrow Passage to the Ladder (the entrance gallery) (Potter Creek)"/>
  <meta name="description" content="Existence and left-turning route of the passage, its termination at the pit margin, the anchoring stalagmite pillar, the ossiferous-earth floor and the 6-18 in bone/charcoal basin."/>
  <meta name="rights" content="Interpretive: Length, width and height (unsurveyed), cross-section shape, lighting and dressing. LAYOUT: global_position/level_order/stream_bbox are interpretive staging for the unified walkable level, not survey g"/>
</head>
