<X3D profile="Immersive" version="4.0">
<head>
  <meta name="title" content="The Great Pit (42 ft entrance descent / rope ladder) (Potter Creek)"/>
  <meta name="description" content="The 42 ft vertical descent itself, the rope-ladder access and the stalagmite-pillar anchor; its position near the NW end of the chamber."/>
  <meta name="rights" content="Interpretive: Pit plan diameter (unsurveyed; ~8 ft in the model), the daylight beam, dust motes and all lighting. LAYOUT: this is the start_room; global_position/level_order/stream_bbox are interpretive staging for"/>
</head>
