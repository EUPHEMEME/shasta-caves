<?xml version="1.0" encoding="UTF-8"?>
<X3D profile="Immersive" version="4.0">
<head>
  <meta name="title" content="Southeast Chimney (above the SE fan apex) (Potter Creek)"/>
  <meta name="description" content="The chimneys existence above the SE apex, that it sub-divides into impassable openings toward the surface, and that a bone-bearing pocket leads off it."/>
  <meta name="rights" content="Interpretive: Height and diameter (unsurveyed; ~30 ft in the model), exact branching geometry. LAYOUT: global_position/level_order/stream_bbox are interpretive staging for the unified walkable level, not survey geo"/>
</head>
