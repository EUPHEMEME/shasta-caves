<X3D profile="Immersive" version="4.0">
<head>
  <meta name="title" content="Vestibule (the smaller entrance chamber) (Potter Creek)"/>
  <meta name="description" content="Existence of the smaller chamber, its role as the antechamber to the narrow passage, the &gt;5.5 ft ossiferous-earth deposit on a NW-pitching limestone floor, and the side-cavities."/>
  <meta name="rights" content="Interpretive: Plan dimensions and ceiling height (unsurveyed), exact shape, speleothems, colour and lighting. LAYOUT: global_position/level_order/stream_bbox are interpretive staging for the unified walkable level,"/>
</head>
