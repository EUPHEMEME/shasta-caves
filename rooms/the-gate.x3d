<?xml version="1.0" encoding="UTF-8"?>
<X3D profile="Immersive" version="4.0">
<head>
  <meta name="title" content="the Gate (Samwel)"/>
  <meta name="description" content="the Gate is a named narrow passage in Furlongs plan as redrawn by Feranec et al. (2007), joining Pleistocene Hall to Chamber One."/>
  <meta name="rights" content="Interpretive: Its bore radius and length, the exact label position, and that it is rendered as a smooth tube; the survey gives no passage dimensions. LAYOUT: global_position/level_order/stream_bbox are interpretive"/>
</head>
