    <ROUTE fromNode='ModeSwitch' fromField='runOn'  toNode='RunTimer'  toField='enabled'/>
    <ROUTE fromNode='ModeSwitch' fromField='jumpOn' toNode='JumpTimer' toField='enabled'/>
